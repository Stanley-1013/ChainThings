# === Supabase ===
# Browser-facing URL
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side URL (Docker overrides to http://supabase-kong:8000)
SUPABASE_URL=http://localhost:8000
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_COOKIE_NAME=sb-chainthings-auth-token

# === AI Gateway ===
# Default provider: zeroclaw or openclaw
# DEFAULT_AI_PROVIDER=zeroclaw
# Dev: http://localhost:42617, Docker overrides to http://zeroclaw:42617
ZEROCLAW_GATEWAY_URL=http://localhost:42617
# Obtain via: POST http://localhost:42617/pair with X-Pairing-Code header
ZEROCLAW_GATEWAY_TOKEN=
# ZEROCLAW_TIMEOUT_MS=30000
# AI chat request timeout (separate from embedding). Fallback: ZEROCLAW_TIMEOUT_MS
# ZEROCLAW_CHAT_TIMEOUT_MS=60000
# RAG stage timeout (embedding + RPC search + memory query)
# RAG_TIMEOUT_MS=10000
# Enable automatic memory extraction from chat conversations
# AI_MEMORY_EXTRACTION=true

# === OpenClaw (legacy, optional) ===
# OPENCLAW_GATEWAY_URL=http://localhost:18789
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_TIMEOUT_MS=30000

# === n8n ===
# Dev: http://localhost:5678, Docker overrides to http://n8n-n8n-1:5678
N8N_API_URL=http://localhost:5678
N8N_API_KEY=
# Public-facing n8n URL for webhook endpoints (e.g. ngrok URL)
N8N_WEBHOOK_URL=
# n8n editor URL for frontend links (falls back to N8N_WEBHOOK_URL for same-origin deployments)
# Only set if your editor and webhook hosts differ
# N8N_EDITOR_BASE_URL=
# N8N_TIMEOUT_MS=10000

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3001
# HMAC secret for webhook authentication (generate with: openssl rand -hex 32)
CHAINTHINGS_WEBHOOK_SECRET=

# === Notifications ===
# Secret for cron-triggered notification generation endpoint
# CRON_SECRET=

# === ngrok (optional, for multi-account tunnel setup) ===
# Override if your app and n8n domains are on different ngrok accounts
# NGROK_CFG_APP=~/.config/ngrok/ngrok.yml
# NGROK_CFG_N8N=~/.config/ngrok/ngrok.yml
